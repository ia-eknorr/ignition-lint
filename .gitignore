# Python cache
**/__pycache__/
**/*.egg-info

# macOS system files
.DS_Store
**/.DS_Store

# Debug directories (exclude golden test files)
**/debug/*
!scripts/debug/*
!tests/debug/
!tests/debug/cases/
!tests/debug/cases/**

# Ignore pylint debug files and temporary files
debug/*.py
debug/pylint_output.txt
tests/debug/*.py
tests/debug/pylint_output.txt

# User repo debug directory (created by PylintScriptRule)
.ignition-lint/

# Local testing tools
bin/
.cache/
.actrc
.github/act-secrets.env

# Build artifacts
dist/

# Jython cache
**/.jython_cache/

# Ignition specific content
.resources/
